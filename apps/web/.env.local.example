# Copy to .env.local for Next.js. Public vars must be prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Azure AD B2C (optional — if unset, /contacts uses dev-only manual bearer / dev-local)
# NEXT_PUBLIC_AZURE_AD_B2C_CLIENT_ID=
# NEXT_PUBLIC_AZURE_AD_B2C_TENANT_NAME=
# NEXT_PUBLIC_AZURE_AD_B2C_TENANT_ID=
# NEXT_PUBLIC_AZURE_AD_B2C_POLICY=B2C_1_signupsignin1
# Optional: default is {TENANT_NAME}.b2clogin.com
# NEXT_PUBLIC_AZURE_AD_B2C_KNOWN_AUTHORITIES=
# API scope(s) for access token — must match FastAPI AZURE_AD_B2C_AUDIENCE / app registration
# NEXT_PUBLIC_AZURE_AD_B2C_API_SCOPES=api://YOUR_API_APP_ID/access_as_user

# Hide dev token textbox in development (production always hides)
# NEXT_PUBLIC_DEV_TOKEN_UI=true

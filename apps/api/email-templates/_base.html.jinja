{#
  _base.html.jinja — branded email shell for all jp-adopt-core drip and
  digest templates. Ports the wrapHtml() layout used by jp-adopt-forms
  (src/lib/acs-email.ts) so user-facing emails feel like one product
  across both apps.

  Visual contract:
    • 600px-wide white card on light gray background (#f3f4f6)
    • Dark header bar (#303030) with the white JP logo, matching site nav
    • 4px orange accent stripe (#eb5f1e) under the header
    • Footer with brand links + copyright
    • Headings inside {% block body %} should use color:#2C474B (dark teal)
      to match the forms email visual language

  Step templates extend this and override {% block body %}:
    {% extends "_base.html.jinja" %}
    {% block body %}
      <h2 style="margin:0 0 16px;color:#2C474B;font-size:18px">Welcome…</h2>
      <p style="margin:0 0 16px;color:#374151">Body content…</p>
    {% endblock %}

  Globally available in {% block body %}:
    {{ contact_display_name }}, {{ campaign_name }}, {{ step_position }}
    (whatever each surface's renderer puts in context)

  Always available from render_step_html:
    {{ current_year }} — for the footer copyright
#}
<!DOCTYPE html>
<html>
<head><meta charset="utf-8"></head>
<body style="margin:0;padding:0;background:#f3f4f6;font-family:Arial,Helvetica,sans-serif">
<table width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6;padding:32px 0">
<tr><td align="center">
<table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;overflow:hidden">

  {# Header — matches site navbar (#303030 bg, white JP logo) #}
  <tr><td style="background:#303030;padding:20px 32px">
    <a href="https://joshuaproject.net" style="text-decoration:none">
      <img src="https://joshuaproject.net/assets/img/logos/jp-logo-header-white.svg" alt="Joshua Project" height="28" style="display:block" />
    </a>
  </td></tr>

  {# Orange accent stripe #}
  <tr><td style="background:#eb5f1e;height:4px;font-size:0;line-height:0">&nbsp;</td></tr>

  {# Body — supplied by the child template #}
  <tr><td style="padding:32px">
    {% block body %}{% endblock %}
  </td></tr>

  {# Footer #}
  <tr><td style="padding:24px 32px;background:#f5f5f5;border-top:1px solid #e5e7eb;text-align:center">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr><td align="center" style="font-size:13px;color:#6b7280;line-height:20px">
        <a href="https://joshuaproject.net/adopt" style="color:#eb5f1e;text-decoration:none">Adopt a People Group</a>
        &middot; <a href="https://joshuaproject.net" style="color:#6b7280;text-decoration:none">joshuaproject.net</a>
        &middot; <a href="https://joshuaproject.net/contact" style="color:#6b7280;text-decoration:none">Contact Us</a>
        &middot; <a href="https://joshuaproject.net/help/privacy" style="color:#6b7280;text-decoration:none">Privacy</a>
      </td></tr>
      <tr><td align="center" style="font-size:12px;color:#9ca3af;padding-top:12px">
        &copy; {{ current_year }} Joshua Project
      </td></tr>
    </table>
  </td></tr>

</table></td></tr></table>
</body></html>

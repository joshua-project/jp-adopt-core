# Copy to .env at repo root for local tooling, or set per app as documented in docs/runbooks/spike-local-dev.md

# --- Runtime environment (API) ---
# development | staging | production. When production or prod, STRICT_AUTH must be true (API refuses to start otherwise).
# APP_ENV=development

# --- Database & cache (docker-compose defaults) ---
# Async URL used by FastAPI, worker, and Alembic (see apps/api/alembic/env.py — async engine).
DATABASE_URL=postgresql+asyncpg://jp_adopt:jp_adopt@localhost:5432/jp_adopt
REDIS_URL=redis://localhost:6379/0

# --- Azure AD B2C (API JWT validation + Next sign-in) ---
# Tenant subdomain (e.g. contoso from contoso.b2clogin.com)
AZURE_AD_B2C_TENANT_NAME=your-tenant-subdomain
# Directory (tenant) ID GUID from Azure portal
AZURE_AD_B2C_TENANT_ID=00000000-0000-0000-0000-000000000000
# App registration (SPA or web) client ID used by Next.js
AZURE_AD_B2C_CLIENT_ID=00000000-0000-0000-0000-000000000001
# Client secret for NextAuth server-side token exchange (confidential client)
AZURE_AD_B2C_CLIENT_SECRET=replace-me
# User flow / policy name, e.g. B2C_1_signupsignin1
AZURE_AD_B2C_POLICY=B2C_1_signupsignin1
# API audience: usually the API application's Application ID URI or its client id
AZURE_AD_B2C_AUDIENCE=00000000-0000-0000-0000-000000000002
# Optional override for JWKS URL (default is derived from tenant + policy)
# AZURE_AD_B2C_JWKS_URI=https://your-tenant.b2clogin.com/your-tenant-id/your-policy/discovery/v2.0/keys

# --- API behavior ---
# When false, accepts Authorization: Bearer dev-local (see runbook). Production must use true.
STRICT_AUTH=false

# --- Integration webhook (worker) ---
INTEGRATION_WEBHOOK_URL=https://example.com/webhooks/jp-adopt
WEBHOOK_HMAC_SECRET=change-me-to-a-long-random-string

# --- Next.js (apps/web) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXT_PUBLIC_API_URL=http://localhost:8000
# Scope string: openid profile offline_access + your API scope URI
AZURE_AD_B2C_SCOPE=openid offline_access

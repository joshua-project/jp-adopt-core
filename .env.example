# Copy to .env at repo root for local tooling, or set per app as documented in docs/runbooks/spike-local-dev.md

# --- Database & cache (docker-compose defaults) ---
# Async URL used by FastAPI, worker, and Alembic (see apps/api/alembic/env.py — async engine).
DATABASE_URL=postgresql+asyncpg://jp_adopt:jp_adopt@localhost:5434/jp_adopt
REDIS_URL=redis://localhost:6379/0

# --- Azure AD B2C (API JWT validation + Next sign-in) ---
# Tenant subdomain (e.g. contoso from contoso.b2clogin.com)
AZURE_AD_B2C_TENANT_NAME=your-tenant-subdomain
# Directory (tenant) ID GUID from Azure portal
AZURE_AD_B2C_TENANT_ID=00000000-0000-0000-0000-000000000000
# App registration (SPA or web) client ID used by Next.js
AZURE_AD_B2C_CLIENT_ID=00000000-0000-0000-0000-000000000001
# Client secret for NextAuth server-side token exchange (confidential client)
AZURE_AD_B2C_CLIENT_SECRET=replace-me
# User flow / policy name, e.g. B2C_1_signupsignin1
AZURE_AD_B2C_POLICY=B2C_1_signupsignin1
# API audience: usually the API application's Application ID URI or its client id
AZURE_AD_B2C_AUDIENCE=00000000-0000-0000-0000-000000000002
# Optional override for JWKS URL (default is derived from tenant + policy)
# AZURE_AD_B2C_JWKS_URI=https://your-tenant.b2clogin.com/your-tenant-id/your-policy/discovery/v2.0/keys

# --- API behavior ---
# When false, accepts Authorization: Bearer dev-local (see runbook). Production must use true.
STRICT_AUTH=false
# Production only: comma-separated browser origins for CORS (non-prod allows localhost/127.0.0.1 on any port).
# CORS_ALLOW_ORIGINS=https://crm.example.com,https://staff.example.com

# --- Integration webhook (worker) ---
INTEGRATION_WEBHOOK_URL=https://example.com/webhooks/jp-adopt
WEBHOOK_HMAC_SECRET=change-me-to-a-long-random-string

# --- Multi-IdP (U3) ---
# IdP dispatch happens in jp_adopt_api.auth.authenticate_bearer_async by
# matching the token's ``iss`` claim against B2C/Entra/magic-link regexes.
# There is intentionally no IDENTITY_PROVIDER discriminator setting.
# Magic-link side-car. >=32 bytes required when APP_ENV=production.
# Generate with: openssl rand -base64 48
MAGIC_LINK_SIGNING_KEY=dev-magic-link-signing-key-please-change-32b
# Public web URL where the click target lives.
MAGIC_LINK_CLICK_BASE_URL=http://localhost:3000
# Entra direct side-car: aud claim required on partner-tenant tokens.
ENTRA_DIRECT_AUDIENCE=api://jp-adopt-core
# Azure Communication Services Email. Unset in dev → worker logs click URL instead of sending.
# ACS_CONNECTION_STRING=endpoint=https://...communication.azure.com/;accesskey=...
ACS_SENDER_ADDRESS=donotreply@joshuaproject.net

# --- Intake endpoints (U4) ---
# Comma-separated bearer API keys accepted by /v1/intake/{adoption,facilitation}.
# Empty in production is rejected at request time (503 intake_disabled).
# Rotate by sending the new key first, then removing the old after forms-app cuts over.
INTAKE_API_KEYS=
# Default origin tag for submissions that don't set one. One of:
# core_org, website, third_party_referral, partner_event, manual_entry, other
INTAKE_DEFAULT_ORIGIN=website

# --- Next.js (apps/web) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXT_PUBLIC_API_URL=http://localhost:8000
# Scope string: openid profile offline_access + your API scope URI
AZURE_AD_B2C_SCOPE="openid offline_access"
